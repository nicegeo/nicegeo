{
  "name": "nicegeo-ide",
  "displayName": "NiceGeo IDE",
  "description": "NiceGeo language support and diagnostics",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicegeo/nicegeo.git"
  },
  "version": "0.2.0",
  "publisher": "nicegeo",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "check-types": "tsc --noEmit -p . && tsc --noEmit -p server/tsconfig.json && tsc --noEmit -p client/visual/tsconfig.json",
    "clean": "node esbuild.config.mjs --clean",
    "build": "node esbuild.config.mjs",
    "compile": "npm run build",
    "watch": "node esbuild.config.mjs --watch",
    "package": "npm run check-types && node esbuild.config.mjs --production",
    "vscode:prepublish": "npm run package"
  },
  "dependencies": {
    "@vscode-elements/elements": "^1.9.1",
    "@vscode/codicons": "^0.0.45",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.80.0",
    "@types/vscode-webview": "^1.57.5",
    "esbuild": "^0.25.4",
    "typescript": "^5.8.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "nicegeo.diagnostics.showOutput",
        "title": "NiceGeo: Show Diagnostics Output"
      },
      {
        "command": "nicegeo.diagnostics.run",
        "title": "NiceGeo: Run Diagnostics"
      },
      {
        "command": "nicegeo.proofMode.enter",
        "category": "NiceGeo",
        "title": "Enter Proof Mode"
      },
      {
        "command": "nicegeo.proofMode.exit",
        "category": "NiceGeo",
        "title": "Exit Proof Mode"
      },
      {
        "command": "nicegeo.proofMode.toggle",
        "category": "NiceGeo",
        "title": "Toggle Proof Mode"
      },
      {
        "command": "nicegeo.visualEditor.open",
        "category": "NiceGeo",
        "title": "Open Visual Editor"
      },
      {
        "command": "nicegeo.walkthrough.openQuickSample",
        "category": "NiceGeo",
        "title": "Open walkthrough quick sample"
      },
      {
        "command": "nicegeo.walkthrough.openProofTutorial",
        "category": "NiceGeo",
        "title": "Open walkthrough tutorial"
      },
      {
        "command": "nicegeo.walkthrough.ackQuickstartMore",
        "category": "NiceGeo",
        "title": "Walkthrough: mark quick start finished"
      },
      {
        "command": "nicegeo.walkthrough.ackProofPlay",
        "category": "NiceGeo",
        "title": "Walkthrough: mark proof tutorial finished"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "nicegeo.proofMode.enter",
          "when": "editorLangId == nicegeo && !nicegeo.proofMode",
          "group": "navigation@49"
        },
        {
          "command": "nicegeo.proofMode.exit",
          "when": "editorLangId == nicegeo && nicegeo.proofMode",
          "group": "navigation@51"
        }
      ]
    },
    "views": {
      "nicegeoSidebar": [
        {
          "id": "nicegeoProofStateWebview",
          "name": "Proof State",
          "type": "webview"
        }
      ]
    },
    "languages": [
      {
        "id": "nicegeo",
        "aliases": [
          "NiceGeo",
          "nicegeo"
        ],
        "extensions": [
          ".ncg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nicegeo",
        "scopeName": "source.nicegeo",
        "path": "./syntaxes/nicegeo.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "nicegeo",
        "path": "./snippets/nicegeo.code-snippets"
      }
    ],
    "configuration": {
      "title": "NiceGeo",
      "properties": {
        "nicegeo.diagnostics.trigger": {
          "type": "string",
          "default": "onSave",
          "enum": [
            "onSave",
            "onType",
            "both"
          ],
          "description": "When to run NiceGeo diagnostics."
        },
        "nicegeo.diagnostics.debounceMs": {
          "type": "number",
          "default": 650,
          "minimum": 100,
          "maximum": 10000,
          "description": "Debounce delay in milliseconds for on-type diagnostics."
        },
        "nicegeo.execution.mode": {
          "type": "string",
          "default": "dune",
          "enum": [
            "dune",
            "installedBinary"
          ],
          "description": "How nicegeo commands are launched. Use dune to run in the project, or installedBinary to run the nicegeo binaries from PATH."
        },
        "nicegeo.proofState.followCursor": {
          "type": "boolean",
          "default": true,
          "description": "While proof mode is on and the NiceGeo Proof State view is visible, refresh proof state as the cursor moves (tactic prefix before the cursor)."
        },
        "nicegeo.proofState.followCursorDebounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 5000,
          "description": "Debounce for follow-cursor proof state updates (milliseconds)."
        },
        "nicegeo.completion.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable NiceGeo language server autocompletion."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nicegeoSidebar",
          "title": "NiceGeo",
          "icon": "media/nicegeo-view.svg"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "nicegeo.quickstart",
        "title": "NiceGeo: Quick start",
        "description": "See what the extension does, open a sample file, and run diagnostics.",
        "steps": [
          {
            "id": "nicegeo.quickstart.welcome",
            "title": "What is NiceGeo IDE?",
            "description": "This extension adds **NiceGeo** (`.ncg`) support in VS Code: diagnostics, completion, hover, go-to-definition, **Proof Mode** with a live **Proof State** panel, and an optional visual editor.\n\nUse the overview on the right, then continue with the next step.",
            "media": {
              "markdown": "media/walkthrough/quickstart-welcome.md"
            }
          },
          {
            "id": "nicegeo.quickstart.toolchain",
            "title": "Toolchain and settings",
            "description": "Checks run on your machine via **opam** / **dune** (or a **nicegeo** binary on `PATH`, depending on settings). Install project deps from the NiceGeo repo when you work on real proofs.\n\nSearch settings for `nicegeo` to tune diagnostics and execution.",
            "media": {
              "markdown": "media/walkthrough/quickstart-toolchain.md"
            }
          },
          {
            "id": "nicegeo.quickstart.sample",
            "title": "Open the quick sample",
            "description": "Open a tiny bundled `.ncg` in a split editor so the language server attaches.\n\n[Open quick sample](command:nicegeo.walkthrough.openQuickSample)",
            "media": {
              "markdown": "media/walkthrough/quickstart-sample.md"
            },
            "completionEvents": [
              "onCommand:nicegeo.walkthrough.openQuickSample"
            ]
          },
          {
            "id": "nicegeo.quickstart.diagnostics",
            "title": "Run diagnostics",
            "description": "With the **quick sample** editor focused, run a check manually (or rely on save/on-type if configured).\n\n[Run diagnostics](command:nicegeo.diagnostics.run)",
            "media": {
              "markdown": "media/walkthrough/quickstart-diagnostics.md"
            },
            "completionEvents": [
              "onCommand:nicegeo.diagnostics.run"
            ]
          },
          {
            "id": "nicegeo.quickstart.more",
            "title": "Go further",
            "description": "Try **completion** (`Ctrl+Space` / `Cmd+Space`), then the **Proof Mode** walkthrough for the Proof State sidebar.\n\nOptionally [open the Visual Editor](command:nicegeo.visualEditor.open), or [mark this step complete](command:nicegeo.walkthrough.ackQuickstartMore).",
            "media": {
              "markdown": "media/walkthrough/quickstart-more.md"
            },
            "completionEvents": [
              "onCommand:nicegeo.visualEditor.open",
              "onCommand:nicegeo.walkthrough.ackQuickstartMore"
            ]
          }
        ]
      },
      {
        "id": "nicegeo.proofMode",
        "title": "NiceGeo: Proof Mode tutorial",
        "description": "Turn on Proof Mode, open Proof State, and follow a bundled tutorial file.",
        "steps": [
          {
            "id": "nicegeo.proofMode.intro",
            "title": "Proof Mode in brief",
            "description": "**Proof Mode** asks the language server for proof state **up to your cursor** inside tactic scripts. The **Proof State** view shows goals, hypotheses, and progress as you move the caret.\n\nRead the panel on the right, then continue.",
            "media": {
              "markdown": "media/walkthrough/proof-intro.md"
            }
          },
          {
            "id": "nicegeo.proofMode.openTutorial",
            "title": "Open the tutorial file",
            "description": "Open the walkthrough `.ncg` beside this page. It is read-only inside the extension folder—use **File → Save As…** if you want a writable copy in your workspace.\n\n[Open walkthrough tutorial](command:nicegeo.walkthrough.openProofTutorial)",
            "media": {
              "markdown": "media/walkthrough/proof-open-tutorial.md"
            },
            "completionEvents": [
              "onCommand:nicegeo.walkthrough.openProofTutorial"
            ]
          },
          {
            "id": "nicegeo.proofMode.enter",
            "title": "Enter Proof Mode",
            "description": "With the tutorial file focused, turn proof tracking on.\n\n[Enter Proof Mode](command:nicegeo.proofMode.enter)",
            "media": {
              "markdown": "media/walkthrough/proof-enter-mode.md"
            },
            "completionEvents": [
              "onCommand:nicegeo.proofMode.enter"
            ]
          },
          {
            "id": "nicegeo.proofMode.sidebar",
            "title": "Show Proof State",
            "description": "Open the **NiceGeo** activity bar entry, then the **Proof State** view. You can also [focus the NiceGeo side bar](command:workbench.view.extension.nicegeoSidebar).\n\nMove the cursor inside a `Proof.` … `Qed.` block to see updates.",
            "media": {
              "markdown": "media/walkthrough/proof-sidebar.md"
            },
            "completionEvents": [
              "onView:nicegeoProofStateWebview"
            ]
          },
          {
            "id": "nicegeo.proofMode.play",
            "title": "Explore the tutorial",
            "description": "In the tutorial file, step through tactics with the caret, use **hover** and **F12** on names, and watch **Proof State**.\n\n[Mark this step complete](command:nicegeo.walkthrough.ackProofPlay)",
            "media": {
              "markdown": "media/walkthrough/proof-play.md"
            },
            "completionEvents": [
              "onCommand:nicegeo.walkthrough.ackProofPlay"
            ]
          }
        ]
      }
    ]
  }
}
