{
  "name": "nicegeo-ide",
  "displayName": "NiceGeo IDE",
  "description": "NiceGeo language support and diagnostics",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicegeo/nicegeo.git"
  },
  "version": "0.1.0",
  "publisher": "nicegeo",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "compile:server": "tsc -p server/tsconfig.json",
    "compile": "npm run compile:server && tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.8.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "nicegeo.diagnostics.showOutput",
        "title": "NiceGeo: Show Diagnostics Output"
      },
      {
        "command": "nicegeo.diagnostics.run",
        "title": "NiceGeo: Run Diagnostics"
      },
      {
        "command": "nicegeo.proofMode.enter",
        "category": "NiceGeo",
        "title": "Enter Proof Mode"
      },
      {
        "command": "nicegeo.proofMode.exit",
        "category": "NiceGeo",
        "title": "Exit Proof Mode"
      },
      {
        "command": "nicegeo.proofMode.toggle",
        "category": "NiceGeo",
        "title": "Toggle Proof Mode"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "nicegeo.proofMode.enter",
          "when": "editorLangId == nicegeo && !nicegeo.proofMode",
          "group": "navigation@49"
        },
        {
          "command": "nicegeo.proofMode.exit",
          "when": "editorLangId == nicegeo && nicegeo.proofMode",
          "group": "navigation@51"
        }
      ]
    },
    "views": {
      "nicegeoSidebar": [
        {
          "id": "nicegeoProofStateWebview",
          "name": "Proof State",
          "type": "webview"
        }
      ]
    },
    "languages": [
      {
        "id": "nicegeo",
        "aliases": [
          "NiceGeo",
          "nicegeo"
        ],
        "extensions": [
          ".ncg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nicegeo",
        "scopeName": "source.nicegeo",
        "path": "./syntaxes/nicegeo.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "nicegeo",
        "path": "./snippets/nicegeo.code-snippets"
      }
    ],
    "configuration": {
      "title": "NiceGeo",
      "properties": {
        "nicegeo.diagnostics.trigger": {
          "type": "string",
          "default": "onSave",
          "enum": [
            "onSave",
            "onType",
            "both"
          ],
          "description": "When to run NiceGeo diagnostics."
        },
        "nicegeo.diagnostics.debounceMs": {
          "type": "number",
          "default": 650,
          "minimum": 100,
          "maximum": 10000,
          "description": "Debounce delay in milliseconds for on-type diagnostics."
        },
        "nicegeo.proofState.followCursor": {
          "type": "boolean",
          "default": true,
          "description": "While proof mode is on and the NiceGeo Proof State view is visible, refresh proof state as the cursor moves (tactic prefix before the cursor)."
        },
        "nicegeo.proofState.followCursorDebounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 5000,
          "description": "Debounce for follow-cursor proof state updates (milliseconds)."
        },
        "nicegeo.completion.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable NiceGeo language server autocompletion."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nicegeoSidebar",
          "title": "NiceGeo",
          "icon": "media/nicegeo-view.svg"
        }
      ]
    }
  }
}
