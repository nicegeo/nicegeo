(* theorems used by automation (todo: move these to a prelude/stdlib) *)

(* rewrite *)
Theorem Eq.symm : (A: Type) -> (a: A) -> (b: A) -> a = b -> b = a :=
    fun (A: Type) (a b : A) (eq_ab : a = b) =>
        Eq.elim A a (fun (x : A) => x = a) (Eq.intro A a) b eq_ab

Theorem EqTrans : (T: Type) -> (a: T) -> (b: T) -> (c: T) -> a = b -> b = c -> a = c :=
    fun T a b c h1 h2 =>
    Eq.elim T b (fun x => a = x) h1 c h2

(* measure *)
Theorem AddLeftRewrite : ∀ (a a1 b c : Measure), a + b = c → a1 = a → a1 + b = c
Proof.
intros a a1 b c abc a1a.
rewrite a1a.
exact abc.
Qed.

Theorem AddRightComm : ∀ (a b c : Measure), a + b + c = a + c + b
Proof.
intros a b c.
rewrite (AddAssoc a b c).
rewrite (AddComm b c).
rewrite (Eq.symm _ _ _ (AddAssoc a c b)).
reflexivity.
Qed.

Theorem AddCongRight : ∀ (x y z : Measure), x = y -> x + z = y + z :=
    fun x y z h =>
    Eq.elim _ x (fun t => x + z = t + z) (Eq.intro _ _) y h

Theorem AddCongLeft : ∀ (x y z : Measure), x = y -> z + x = z + y :=
    fun x y z h =>
    Eq.elim _ x (fun t => z + x = z + t) (Eq.intro _ _) y h

Theorem LtNe : (a: Measure) -> (b: Measure) -> a < b -> a ≠ b :=
    fun (a: Measure) (b: Measure) (lt_ab: a < b) (eq_ab: a = b) =>
        LtAntisymm b b
            (Eq.elim Measure a (fun (x: Measure) => x < b) lt_ab b eq_ab)
            (Eq.elim Measure a (fun (x: Measure) => x < b) lt_ab b eq_ab)

Theorem AddCancel : ∀ (x y z : Measure), x + z = y + z -> x = y :=
    fun x y z h =>
    Or.elim _ _ _ (LtTricot x y)
    (fun (xly : x < y) =>
        False.elim _ (LtNe _ _ (LtAdd x y z xly) h))
    (fun rest =>
    Or.elim _ _ _ rest
    (fun (ylx: y < x) =>
        False.elim _ (LtNe _ _ (LtAdd y x z ylx) (Eq.symm _ _ _ h)))
    (fun (eqxy : x = y) => eqxy))

Theorem LtCancelLeft : ∀ (x y z : Measure), z + x < z + y -> x < y :=
    fun (x y z : Measure) (h : z + x < z + y) =>
    Or.elim _ _ _ (LtTricot x y)
        (fun (x_lt_y : x < y) => x_lt_y)
        (fun (rest : y < x \/ x = y) =>
        Or.elim _ _ _ rest
            (fun (y_lt_x : y < x) =>
                False.elim _ (LtAntisymm _ _ h
                    (Eq.elim _ _ (fun t => t < z + x)
                        (Eq.elim _ _ (fun t => y + z < t)
                            (LtAdd y x z y_lt_x)
                            _
                            (AddComm x z))
                        _
                        (AddComm y z))))
            (fun (x_eq_y : x = y) =>
                False.elim _ (LtIrrefl (z + y)
                    (Eq.elim _ _ (fun t => t < z + y)
                        h
                        _
                        (AddCongLeft x y z x_eq_y)))))

Theorem LtCancelRight : ∀ (x y z : Measure), x + z < y + z -> x < y :=
    fun (x y z : Measure) (h : x + z < y + z) =>
    LtCancelLeft x y z
        (Eq.elim _ _ (fun t => t < z + y)
            (Eq.elim _ _ (fun t => x + z < t)
                h
                _
                (AddComm y z))
            _
            (AddComm x z))


Theorem LtZero : ∀ (a : Measure), a < Zero → False
Proof.
intros a ha.
cases (ZeroLeast a) h.
exact (LtAntisymm _ _ ha h).
exact (LtNe _ _ ha (Eq.symm _ _ _ h)).
Qed.

(* Zero is a left identity for addition: 0 + a = a. *)
Theorem ZeroAdd : (a: Measure) -> Zero + a = a :=
    fun (a: Measure) => Eq.elim _ _ (fun x => x = a) (AddZero a) _ (AddComm a Zero)

Theorem EqByContra : ∀ (a b : Measure), ¬a < b → ¬b < a → a = b
Proof.
intros a b nab nba.
cases (LtTricot a b) h.
apply (False.elim _).
exact (nab h).
cases h h1.
apply (False.elim _).
exact (nba h1).
exact h1.
Qed.

(* intro tests *)

Theorem intro_unwraps_defs : ∀ (a b : Point), a ≠ b → a ≠ b
Proof.
intros a b ab_ne.
intro ab. (* goal is a ≠ b, intros a = b with goal False *)
exact (ab_ne ab).
Qed.

(* have tests *)

(* have with unspecified type inferred from proof *)
Theorem havetest : ∀ (A B C : Prop), A ∧ B ∧ C → C ∧ B ∧ A
Proof.
intros A B C h.
destruct_ands h a b c.
have cb _.
	exact (And.intro _ _ c b).
exact (And.intro _ _ cb a).
Qed.

(* destruct_and tests *)

Theorem test1 : ∀ (A B C D E : Prop), A ∧ B ∧ C ∧ D ∧ E → D 
Proof.
intros A B C D E h.
destruct_ands h a b c d e.
exact d.
Qed.

Theorem test2 : ∀ (A B C D E : Prop), A ∧ (B ∧ (C ∧ (D ∧ E))) → D 
Proof.
intros A B C D E h.
destruct_ands h a b c d e.
exact d.
Qed.

Theorem test3 : ∀ (A B C D E : Prop), (A ∧ B) ∧ (C ∧ (D ∧ E)) → D 
Proof.
intros A B C D E h.
destruct_ands h a b c d e.
exact d.
Qed.

(* showing definition unfolding behavior *)
Definition OutCircle : Point → Circle → Prop := fun a α => ¬OnCircle a α ∧ ¬InCircle a α

Theorem test4 : ∀ a α, a = a ∧ OutCircle a α ∧ α = α → ¬InCircle a α 
Proof.
intros a α h.
destruct_ands h a_rfl outcircle α_rfl.
destruct_ands outcircle noton notin.
exact notin.
Qed.

(* this isn't really an automation test but *)
Theorem list_test : ∀ (a b c : Point), ∃ d, ¬List.mem _ d [a, b, c]
Proof.
intros a b c.
choose d hd (pt_exists [a, b, c] [] []).
destruct_ands (distinct_from.elim _ _ _ _ hd) d_not_mem _h2 _h3.
exists d.
exact d_not_mem.
Qed.

(* cases *)

Theorem Or.symm : ∀ (A B : Prop), A ∨ B → B ∨ A
Proof.
intros A B or.
cases or a b.
right.
exact a.
left.
exact b.
Qed.

Theorem Or.symm1 : ∀ (A B : Prop), A ∨ B → B ∨ A
Proof.
intros A B or.
cases or h.
right.
exact h.
left.
exact h.
Qed.

Theorem em : ∀ (P: Prop), P ∨ ¬P
Proof.
intro P.
cases (excluded_middle P) h.
left.
exact h.
right.
exact h.
Qed.

(* measure_norm tests *)

(* it's beautiful *)
Theorem test5 : ∀ (a b c d : Measure), a + b + a + c + d + b = d + (b + b) + (a + (c + a))
Proof.
intros a b c d.
measure_norm.
reflexivity.
Qed.

Theorem test6 : ∀ (a b : Point), Zero + Length a b = Length b a + Zero
Proof.
intros a b.
measure_norm.
reflexivity.
Qed.

(* simp_constrain tests *)

(* sooooo beautiful you can't tell me this isn't amazing *)
Theorem test7 : ∀ (a b c d e f : Measure), a + (b + a + c) + (d + b) + e < d + (b + b + f) + (a + (c + a)) → e < f
Proof.
intros a b c d e f h.
simp_constrain h1 h.
exact h1.
Qed.

Theorem LtAddLeft : ∀ (a b c : Measure), a < b → c + a < c + b
Proof.
intros a b c ab.
rewrite (AddComm c a).
rewrite (AddComm c b).
exact (LtAdd _ _ _ ab).
Qed.

Theorem add_lt_add : ∀ (a b c d : Measure), a < b → c < d → a + c < b + d
Proof.
intros a b c d ab cd.
have h1 (a + c < b + c).
    apply (LtAdd _ _ _).
    exact ab.
have h2 (b + c < b + d).
    apply (LtAddLeft _ _ _).
    exact cd.
exact (LtTrans _ _ _ h1 h2).
Qed.

Theorem add_le_add : ∀ (a b c d : Measure), Le a b → Le c d → Le (a + c) (b + d)
Proof.
intros a b c d hab hcd lt.
cases (LtTricot a b) h.
cases (LtTricot c d) h1.
have h2 _. exact (add_lt_add _ _ _ _ h h1).
exact (LtAntisymm _ _ lt h2).
cases h1 h2.
exact (hcd h2).
(* rewrite h2 at lt. i wish *)
have lt' (b+d<a+d). exact (Eq.elim Measure c (fun x => b + d < a + x) lt d h2).
have h3 _. exact (LtCancelRight _ _ _ lt').
exact (LtAntisymm _ _ h h3).
cases h h1.
exact (hab h1).
(* probably shouldn't have intro'd lt. oh well. live and learn. *)
have lt' (b+d<b+c). exact (Eq.elim Measure a (fun x => b + d < x + c) lt b h1).
have h2 _. exact (LtCancelLeft _ _ _ lt').
exact (hcd h2).
Qed.

Theorem LeCancelRight : ∀ (a b c : Measure), Le (a + c) (b + c) → Le a b
Proof.
intros a b c le ab.
have h _. exact (LtAdd _ _ c ab).
exact (le h).
Qed.

Theorem LeAdd : ∀ (a b c : Measure), Le a b → Le (a + c) (b + c)
Proof.
intros a b c ab lt.
have h _. exact (LtCancelRight _ _ _ lt).
exact (ab h).
Qed.

Theorem LtLeLt : ∀ (a b c : Measure), a < b → Le b c → a < c
Proof.
intros a b c ab bc.
(* cases () *)
Qed.

Axiom sorry : (P: Prop) → P

Theorem lt_mul_5 : ∀ (a b : Measure), a < b → a + a + a + a + a < b + b + b + b + b :=
	fun a b h =>
	add_lt_add (a+a+a+a) (b+b+b+b) a b (
	add_lt_add (a+a+a) (b+b+b) a b (
	add_lt_add (a+a) (b+b) a b (
	add_lt_add (a) (b) a b (
	h
	) h
	) h
	) h
	) h

(* metric tests *)

Theorem test8 : ∀ (a b c : Measure), a < b → b < c → c < a → False
Proof.
intros a b c h1 h2 h3.
metric.
Qed.

Theorem test9 : ∀ (a b c d e : Measure), a < b → b = c → c < d → d < e → e = a → False
Proof.
intros a b c d e h1 h2 h3 h4 h5.
metric.
Qed.
