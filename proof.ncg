    (fun (MO : para M O) =>
    have _ _ (fst _ _ pLN)
    (fun pAO =>
    have _ _ (snd _ _ pLN)
    (fun (LN : para L N) =>
    have _ _ (fst _ _ pAO)
    (fun pDO =>
    have _ _ (snd _ _ pAO)
    (fun (aO : OnLine a O) =>
    have _ _ (fst _ _ pDO)
    (fun pDN =>
    have _ _ (snd _ _ pDO)
    (fun (dO : OnLine d O) =>
    have _ _ (fst _ _ pDN)
    (fun pCN =>
    have _ _ (snd _ _ pDN)
    (fun (_dN : OnLine d N) =>
    have _ _ (fst _ _ pCN)
    (fun pCM =>
    have _ _ (snd _ _ pCN)
    (fun (cN : OnLine c N) =>
    have _ _ (fst _ _ pCM)
    (fun pBM =>
    have _ _ (snd _ _ pCM)
    (fun (cM : OnLine c M) =>
    have _ _ (fst _ _ pBM)
    (fun pAB =>
    have _ _ (snd _ _ pBM)
    (fun (bM : OnLine b M) =>
