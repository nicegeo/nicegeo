(* Proposition 31: through a point off a line there exists a parallel line *)
Theorem para_of_offline: (a : Point) -> (M : Line) -> (Not (OnLine a M)) -> (Exists Line (fun N => (OnLine a N /\ para M N) )) := sorry _


    
(* Proposition 34: basic length, angle, and area properties of paralellograms *)
Theorem len_ang_arelen_ang_area_eq_of_parallelogram : (a : Point) -> (b : Point) -> (c : Point) -> (d : Point) -> (M : Line) -> (N : Line) -> (O : Line) -> (P : Line) ->
(paragram a b c d M N O P) -> length a b = length c d /\ angle b a d = angle b c d /\ area a b d = area b c d 
:= sorry _

(* Proposition 34.1: basic length properties of parallelograms *)
Theorem len_eq_of_parallelogram :  (a : Point) -> (b : Point) -> (c : Point) -> (d : Point) -> (M : Line) -> (N : Line) -> (O : Line) -> (P : Line) ->
(paragram a b c d M N O P) -> length a b = length c d := sorry _


(* Proposition 34.2:basic length properties of paralellograms *)
Theorem len_eq_of_parallelogram' :  (a : Point) -> (b : Point) -> (c : Point) -> (d : Point) -> (M : Line) -> (N : Line) -> (O : Line) -> (P : Line) ->
(paragram a b c d M N O P) -> length a d = length c b := sorry _

(* Proposition 34.3: basic area properties of paralellograms *)
Theorem len_eq_of_parallelogram'' :  (a : Point) -> (b : Point) -> (c : Point) -> (d : Point) -> (M : Line) -> (N : Line) -> (O : Line) -> (P : Line) ->
(paragram a b c d M N O P) -> area a b d  = area b c d := sorry _


(* Proposition 46 : Constructing a square out of a segment *)
Theorem square_of_len : (a : Point) -> (b : Point) -> a ≠ b -> 
    Exists Point (fun c => Exists Point (fun d => square a b c d)) :=
    sorry _





