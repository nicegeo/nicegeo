    have _ _ (snd _ _ pAB)
    (fun (bL : OnLine b L) =>
    have _ _ (offline_of_para' c L N
        cN
        LN)
    (fun (c_not_on_L : Not (OnLine c L)) =>
    have _ _ (offline_of_para d O M dO (para_symm M O MO))
    (fun (d_not_on_M : Not (OnLine d M)) =>
    swap_12_triangle b d c
        (swap_23_triangle b c d
            (triangle_of_ne_online b c d M
                (ne_of_online_not_online b c L bL c_not_on_L)
                bM
                cM
                d_not_on_M))))))))))))))))))))))

	(* Proposition 34.
	   Core idea: copy triangle dbc across the diagonal bd to a triangle xbd on the
	   opposite side of bd, then use the parallel-side data of the parallelogram to
	   show the copied point x must in fact coincide with a.  The copied side, angle,
	   and area equalities then rewrite to:
	     ab = cd,  angle bad = angle bcd,  area abd = area bcd. *)
	Theorem len_ang_arelen_ang_area_eq_of_parallelogram : ∀ (a b c d : Point) (M N O P : Line),
    paragram a b c d M N O P ->
    length a b = length c d /\ angle b a d = angle b c d /\ area a b d = area b c d :=
    fun (a b c d : Point) (M N O P : Line)
        (pgram : paragram a b c d M N O P) =>
    have _ _ (fst _ _ pgram)
    (fun pMO =>
    have _ _ (snd _ _ pgram)
    (fun (NP : para N P) =>
    have _ _ (fst _ _ pMO)
    (fun pAP =>
    have _ _ (snd _ _ pMO)
    (fun (MO : para M O) =>
    have _ _ (fst _ _ pAP)
    (fun pDP =>
    have _ _ (snd _ _ pAP)
    (fun (aP : OnLine a P) =>
    have _ _ (fst _ _ pDP)
    (fun pDO =>
    have _ _ (snd _ _ pDP)
    (fun (dP : OnLine d P) =>
    have _ _ (fst _ _ pDO)
    (fun pCO =>
    have _ _ (snd _ _ pDO)
    (fun (dO : OnLine d O) =>
    have _ _ (fst _ _ pCO)
    (fun pCN =>
    have _ _ (snd _ _ pCO)
    (fun (cO : OnLine c O) =>
    have _ _ (fst _ _ pCN)
    (fun pBN =>
    have _ _ (snd _ _ pCN)
    (fun (cN : OnLine c N) =>
    have _ _ (fst _ _ pBN)
    (fun pAB =>
    have _ _ (snd _ _ pBN)
    (fun (bN : OnLine b N) =>
    have _ _ (fst _ _ pAB)
    (fun (aM : OnLine a M) =>
    have _ _ (snd _ _ pAB)
    (fun (bM : OnLine b M) =>
    have _ _ (tri124_of_paragram a b c d M N O P pgram)
    (fun (tri_abd : triangle a b d) =>
    have _ _ (tri342_of_paragram a b c d M N O P pgram)
    (fun (tri_dbc : triangle d b c) =>
    have _ _ (ne_23_of_triangle a b d tri_abd)
    (fun (bd : b ≠ d) =>
    Exists.elim _ _ _ (line_of_pts b d bd)
    (fun (T : Line) (bd_on_T : OnLine b T /\ OnLine d T) =>
    have _ _ (diffside_of_paragram a b c d M N O P T
        (fst _ _ bd_on_T)
        (snd _ _ bd_on_T)
        pgram)
    (fun (acT : diffside a c T) =>
    Exists.elim _ _ _ (triangle_copy b d a d b c T
        tri_dbc
        (fst _ _ bd_on_T)
        (snd _ _ bd_on_T)
        (fst _ _ (fst _ _ acT))
        (length_symm b d))
    (fun (x : Point) (hx : Length b x = Length d c /\ Length d x = Length b c /\ SameSide x a T) =>
    have _ _
        (length_pts_ne d c b x
            (Eq.symm _ _ _ (fst _ _ (fst _ _ hx)))
            (ne_13_of_triangle d b c tri_dbc))
    (fun (bx : b ≠ x) =>
    have _ _
        (length_pts_ne b c d x
            (Eq.symm _ _ _ (snd _ _ (fst _ _ hx)))
            (ne_23_of_triangle d b c tri_dbc))
    (fun (dx : d ≠ x) =>
    Exists.elim _ _ _ (line_of_pts b x bx)
    (fun (R : Line) (bx_on_R : OnLine b R /\ OnLine x R) =>
    Exists.elim _ _ _ (line_of_pts d x dx)
    (fun (S : Line) (dx_on_S : OnLine d S /\ OnLine x S) =>
    have _ _
        (diffside_of_sameside_diffside a x c T
            (same_side_symm x a T (snd _ _ hx))
            acT)
    (fun (xcT : diffside x c T) =>
    have _ _
        (sss_congruence x b d c d b
            (Ne.symm _ _ _ bx)
            bd
            (Ne.symm _ _ _ dx)
            (Ne.symm _ _ _ (ne_13_of_triangle d b c tri_dbc))
            (Ne.symm _ _ _ bd)
            (Ne.symm _ _ _ (ne_23_of_triangle d b c tri_dbc))
            (EqTrans _ _ _ _
                (Eq.symm _ _ _ (length_symm b x))
                (EqTrans _ _ _ _
                    (fst _ _ (fst _ _ hx))
                    (length_symm d c)))
            (length_symm b d)
            (snd _ _ (fst _ _ hx)))
    (fun xbd_cdb_all =>
    have _ _
        (EqTrans _ _ _ _
            (Eq.symm _ _ _
                (angle_symm x b d
                    (Ne.symm _ _ _ bx)
                    bd))
            (EqTrans _ _ _ _
                (fst _ _ (snd _ _ xbd_cdb_all))
                (angle_symm c d b
                    (Ne.symm _ _ _ (ne_13_of_triangle d b c tri_dbc))
                    (Ne.symm _ _ _ bd))))
    (fun (dbx_bdc : Angle d b x = Angle b d c) =>
    have _ _
        (para_of_ang_eq x b d c T R O
            bd
            (snd _ _ bx_on_R)
            (fst _ _ bx_on_R)
            (fst _ _ bd_on_T)
            (snd _ _ bd_on_T)
            dO
            cO
            xcT
            dbx_bdc)
    (fun (RO : para R O) =>
    have _ _
        (para_of_ang_eq x d b c T S N
            (Ne.symm _ _ _ bd)
            (snd _ _ dx_on_S)
            (fst _ _ dx_on_S)
            (snd _ _ bd_on_T)
            (fst _ _ bd_on_T)
            bN
            cN
            xcT
            (fst _ _ (snd _ _ (snd _ _ xbd_cdb_all))))
    (fun (SN : para S N) =>
    have _ _
        (eq_line_of_common_point_parallel_same b R M O
            (fst _ _ bx_on_R)
            bM
            RO
            MO)
    (fun (RM : R = M) =>
    have _ _
        (eq_line_of_common_point_parallel_same d S P N
            (fst _ _ dx_on_S)
            dP
            SN
            (para_symm N P NP))
    (fun (SP : S = P) =>
    have _ _
        (Eq.elim _ R (fun Q => OnLine x Q) (snd _ _ bx_on_R) M RM)
    (fun (xM : OnLine x M) =>
    have _ _
        (Eq.elim _ S (fun Q => OnLine x Q) (snd _ _ dx_on_S) P SP)
    (fun (xP : OnLine x P) =>
    have _ _
        (offline_of_para d O M dO (para_symm M O MO))
    (fun (d_not_on_M : Not (OnLine d M)) =>
    have _ _
        (eq_point_of_online_online_ne_line x a M P
            xM
            aM
            xP
            aP
            (ne_line_of_online d M P dP d_not_on_M))
    (fun (xa : x = a) =>
    have _ _
        (EqTrans _ _ _ _
            (length_symm a b)
            (EqTrans _ _ _ _
                (Eq.elim _ x (fun u => Length b u = Length d c)
                    (fst _ _ (fst _ _ hx))
                    a
                    xa)
                (length_symm d c)))
    (fun (ab_cd : length a b = length c d) =>
    have _ _
            (EqTrans _ _ _ _
                (Eq.symm _ _ _ (angle_symm d a b
                    (Ne.symm _ _ _ (ne_13_of_triangle a b d tri_abd))
                    (ne_12_of_triangle a b d tri_abd)))
                (Eq.elim _ x (fun u => Angle d u b = Angle b c d)
                    (snd _ _ (snd _ _ (snd _ _ xbd_cdb_all)))
                    a
                xa))
    (fun (bad_bcd : angle b a d = angle b c d) =>
    have _ _
        (EqTrans _ _ _ _
            (Eq.elim _ x (fun u => Area u b d = Area c d b)
                (fst _ _ xbd_cdb_all)
                a
                xa)
            (fst _ _ (area_perm c d b)))
    (fun (abd_bcd : area a b d = area b c d) =>
    And.intro _ _
        (And.intro _ _
            ab_cd
            bad_bcd)
        abd_bcd))))))))))))))))))))))))))))))))))))))))))

(* Proposition 34.1: Opposite sides of a parallelogram are equal (ab = cd). *)
Theorem len_eq_of_parallelogram : ∀ (a b c d : Point) (M N O P : Line),
    paragram a b c d M N O P -> length a b = length c d :=
    fun (a b c d : Point) (M N O P : Line) (pgram : paragram a b c d M N O P) =>
    fst _ _ (fst _ _ (len_ang_arelen_ang_area_eq_of_parallelogram a b c d M N O P pgram))

	(* Cyclic relabeling of a parallelogram, used to recover the second pair of
	   opposite-side equalities from the first Prop. 34 equality theorem. *)
	Theorem paragram_rotate : ∀ (a b c d : Point) (M N O P : Line),
    paragram a b c d M N O P -> paragram d a b c P M N O :=
    fun (a b c d : Point) (M N O P : Line) (pgram : paragram a b c d M N O P) =>
    have _ _ (fst _ _ pgram)
    (fun pMO =>
    have _ _ (snd _ _ pgram)
    (fun (NP : para N P) =>
    have _ _ (fst _ _ pMO)
    (fun pAP =>
    have _ _ (snd _ _ pMO)
    (fun (MO : para M O) =>
    have _ _ (fst _ _ pAP)
    (fun pDP =>
    have _ _ (snd _ _ pAP)
    (fun (aP : OnLine a P) =>
    have _ _ (fst _ _ pDP)
    (fun pDO =>
    have _ _ (snd _ _ pDP)
    (fun (dP : OnLine d P) =>
    have _ _ (fst _ _ pDO)
    (fun pCO =>
    have _ _ (snd _ _ pDO)
    (fun (dO : OnLine d O) =>
    have _ _ (fst _ _ pCO)
    (fun pCN =>
    have _ _ (snd _ _ pCO)
    (fun (cO : OnLine c O) =>
    have _ _ (fst _ _ pCN)
    (fun pBN =>
    have _ _ (snd _ _ pCN)
    (fun (cN : OnLine c N) =>
    have _ _ (fst _ _ pBN)
    (fun pAB =>
    have _ _ (snd _ _ pBN)
    (fun (bN : OnLine b N) =>
    have _ _ (fst _ _ pAB)
    (fun (aM : OnLine a M) =>
    have _ _ (snd _ _ pAB)
    (fun (bM : OnLine b M) =>
    And.intro _ _
        (And.intro _ _
            (And.intro _ _
                (And.intro _ _
                    (And.intro _ _
                        (And.intro _ _
                            (And.intro _ _
                                (And.intro _ _
                                    (And.intro _ _
                                        dP
                                        aP)
                                    aM)
                                bM)
                            bN)
                        cN)
                    cO)
                dO)
            (para_symm N P NP))
        MO))))))))))))))))))

(* Proposition 34.2: The other pair of opposite sides are equal (ad = cb). *)
Theorem len_eq_of_parallelogram' : ∀ (a b c d : Point) (M N O P : Line),
    paragram a b c d M N O P -> length a d = length c b :=
    fun (a b c d : Point) (M N O P : Line) (pgram : paragram a b c d M N O P) =>
    have _ _ (paragram_rotate a b c d M N O P pgram)
    (fun (pgram_rot : paragram d a b c P M N O) =>
    EqTrans _ _ _ _
        (length_symm a d)
        (EqTrans _ _ _ _
            (len_eq_of_parallelogram d a b c P M N O pgram_rot)
            (length_symm b c)))

(* Proposition 34.3: A diagonal bisects the parallelogram area. *)
Theorem len_eq_of_parallelogram'' : ∀ (a b c d : Point) (M N O P : Line),
    paragram a b c d M N O P -> area a b d = area b c d :=
    fun (a b c d : Point) (M N O P : Line) (pgram : paragram a b c d M N O P) =>
    snd _ _ (len_ang_arelen_ang_area_eq_of_parallelogram a b c d M N O P pgram)

(* ============================================================
   Helpers for Proposition 46
   ============================================================ *)

(* Prop 30 corollary: if a transversal L meets N, then it also meets every line
   parallel to N.  The distinctness L ≠ N is essential: without it the statement
   is false when L = N. *)
Theorem lines_inter_of_parallel_through_transversal :
    ∀ (L N P : Line),
    L ≠ N ->
    LinesInter L N ->
    para N P ->
    LinesInter P L :=
    fun (L N P : Line) (LN : L ≠ N) (hLN : LinesInter L N) (NP : para N P) =>
    Or.elim _ _ _ (excluded_middle (para L P))
    (fun (LP : para L P) =>
        Exists.elim _ _ _ (pt_of_linesinter L N hLN)
        (fun (a : Point) (a_on : OnLine a L /\ OnLine a N) =>
            False.elim _ (
                para_not_inter L N
                    (para_trans L P N LN LP (para_symm N P NP))
                    hLN)))
    (fun (not_LP : Not (para L P)) =>
        Exists.elim _ _ _ (common_point_of_not_para L P not_LP)
        (fun (a : Point) (a_on : OnLine a L /\ OnLine a P) =>
            have _ _
            (fun (PL : P = L) =>
                Exists.elim _ _ _ (pt_of_linesinter L N hLN)
                (fun (x : Point) (x_on : OnLine x L /\ OnLine x N) =>
                    not_para_of_onlines x N P
                        (snd _ _ x_on)
                        (Eq.elim _ L (fun Q => OnLine x Q) (fst _ _ x_on) P (Eq.symm _ _ _ PL))
                        NP))
            (fun (PL : P ≠ L) =>
                lines_inter_of_common_point_distinct a P L PL (snd _ _ a_on) (fst _ _ a_on))))

(* If L and N intersect, then any line parallel to L intersects any line parallel to N.
   Obtained by applying lines_inter_of_parallel_through_transversal twice. *)
Theorem lines_inter_of_crossing_parallels :
    ∀ (L N M P : Line),
    L ≠ N ->
    LinesInter L N ->
    para L M ->
    para N P ->
    LinesInter M P :=
    fun (L N M P : Line) (LN : L ≠ N) (hLN : LinesInter L N) (LM : para L M) (NP : para N P) =>
        lines_inter_of_parallel_through_transversal P L M
            (fun (PL : P = L) =>
                Exists.elim _ _ _ (pt_of_linesinter L N hLN)
                (fun (a : Point) (a_on : OnLine a L /\ OnLine a N) =>
                    not_para_of_onlines a N P
                        (snd _ _ a_on)
                        (Eq.elim _ L (fun Q => OnLine a Q) (fst _ _ a_on) P (Eq.symm _ _ _ PL))
                        NP))
            (lines_inter_of_parallel_through_transversal L N P LN hLN NP)
            LM

(* Points lying on a line parallel to N are on the same side of N,
   provided one known point is already off N. *)
Theorem same_side_of_points_on_parallel :
    ∀ (b e : Point) (N M : Line),
    OnLine b M -> OnLine e M ->
    para N M ->
    Not (OnLine b N) ->
    SameSide b e N :=
    fun (b e : Point) (N M : Line) (b_on_M : OnLine b M) (e_on_M : OnLine e M)
        (hpara : para N M) (b_not_on_N : Not (OnLine b N)) =>
    have _ _ (
        fun (e_on_N : OnLine e N) => hpara e (And.intro _ _ e_on_N e_on_M)
    )
    (fun (e_not_on_N : Not (OnLine e N)) =>
    double_negation (SameSide b e N)
    (fun (b_not_same_e : Not (SameSide b e N)) =>
        para_not_inter N M hpara
        (lines_inter_if_diff_sides b e N M
            (And.intro _ _
                (And.intro _ _
                    b_not_on_N
                    e_not_on_N)
                b_not_same_e)
            b_on_M
            e_on_M))
    )

(* ============================================================
   Proposition 46 (I.46): Constructing a square on a given segment

   Construction plan:
     1. Build the line L through a and b.
     2. Erect a perpendicular N at a, obtaining a point c above L.
     3. Place d on N so that Length a d = Length a b  (via circle aa).
     4. Draw DE ∥ L through d, and BE ∥ N through b  (Prop. 31).
     5. Let e be the intersection of DE and BE.
     6. ADEB is a parallelogram; Prop. 34 gives opposite-side and angle equalities.
     7. AD = AB propagates via Prop. 34 to all four sides.
     8. Prop. 29 on transversal N gives ∠BAD + ∠ADE = 180°; since ∠BAD = 90°,
        ∠ADE = 90°; parallelogram angle equality yields all four angles = 90°.
     9. Witnesses returned in the order (e, d): square a b e d.
   ============================================================ *)

Theorem square_of_len : ∀ (a b : Point), a ≠ b ->
    Exists Point (fun d => Exists Point (fun e => square a b d e)) :=
    fun (a : Point) (b : Point) (ab : a ≠ b) =>

    (* Build the base line AB and choose a side of it. *)
    Exists.elim _ _ _ (line_of_pts a b ab)
    (fun (L : Line) (ab_on_L : OnLine a L /\ OnLine b L) =>

    (* f is only an auxiliary point chosen fresh from the objects mentioned so far,
       in particular so that f is not on L and can be used to pick a side of L. *)
    Exists.elim _ _ _ (pt_exists [] [L] [])
    (fun (f : Point) (hf : distinct_from f [] [L] []) =>

    have _ _ (distinct_from_single_line_not_on f L hf)
    (fun (f_not_on_L : Not (OnLine f L)) =>

    (* Erect the perpendicular through A. *)
    Exists.elim _ _ _ (perpendicular_of_online' b a a f L (Ne.symm _ _ _ ab) (snd _ _ ab_on_L) (fst _ _ ab_on_L) f_not_on_L)
    (fun (c : Point) (hc : SameSide c f L ∧ Angle b a c = 90) =>

    have _ _ (same_side_not_on_line c f L (fst _ _ hc))
    (fun (c_not_on_L : Not (OnLine c L)) =>

    have _ _
    (fun (ca_eq : c = a) => c_not_on_L (Eq.elim _ a (fun x => OnLine x L) (fst _ _ ab_on_L) c (Eq.symm _ _ _ ca_eq)))
    (fun (ca : c ≠ a) =>

    Exists.elim _ _ _ (line_of_pts a c (Ne.symm _ _ _ ca))
    (fun (N : Line) (ac_on_N : OnLine a N /\ OnLine c N) =>

    (* Put D on the perpendicular so that AD = AB. *)
    Exists.elim _ _ _ (circle_of_ne a b ab)
    (fun (aa : Circle) (aa_data : CenterCircle a aa /\ OnCircle b aa) =>

    (* Put d on the perpendicular ray through a so that ad = ab:
       since a is inside the circle centered at a through b, extending the ray ca
       reaches the circle at a point d. *)
    Exists.elim _ _ _ (pt_oncircle_of_inside_ne c a aa ca (center_lies_inside_circle a aa (fst _ _ aa_data)))
    (fun (d : Point) (hd_data : Between c a d /\ OnCircle d aa) =>

    have _ _ (between_collinear_right c a d N (fst _ _ hd_data) (snd _ _ ac_on_N) (fst _ _ ac_on_N))
    (fun (d_on_N : OnLine d N) =>

    have _ _
    (snd _ _ (on_circle_iff_length_eq a b d aa (fst _ _ aa_data) (snd _ _ aa_data)) (snd _ _ hd_data))
    (fun (hd : Length a b = Length a d) =>

    have _ _
    (fun (d_on_L : OnLine d L) =>
        c_not_on_L
        (between_collinear_right d a c L
            (fst _ _ (between_distinct c a d (fst _ _ hd_data)))
            d_on_L
            (fst _ _ ab_on_L)))
    (fun (d_not_on_L : Not (OnLine d L)) =>

    have _ _
    (fun (b_on_N : OnLine b N) =>
        c_not_on_L
        (Eq.elim _ N (fun M => OnLine c M)
            (snd _ _ ac_on_N)
            L
            (Eq.symm _ _ _
                (two_distinct_points_determine_unique_line a b L N ab
                    (fst _ _ ab_on_L) (snd _ _ ab_on_L)
                    (fst _ _ ac_on_N) b_on_N))))
    (fun (b_not_on_N : Not (OnLine b N)) =>

    have _ _
    (lines_inter_if_diff_sides c d L N
        (And.intro _ _
            (And.intro _ _
                c_not_on_L
                d_not_on_L)
            (pasch_online_not_sameside c a d L
                (fst _ _ hd_data)
                (fst _ _ ab_on_L)))
        (snd _ _ ac_on_N)
        d_on_N)
    (fun (hLN_inter : LinesInter L N) =>

    (* Euclid I.46, second step:
       draw through d a line parallel to ab, and through b a line parallel to ad. *)
    Exists.elim _ _ _ (para_of_offline d L d_not_on_L)
    (fun (DE : Line) (hDE : OnLine d DE /\ para L DE) =>

    Exists.elim _ _ _ (para_of_offline b N b_not_on_N)
    (fun (BE : Line) (hBE : OnLine b BE /\ para N BE) =>

    (* The two constructed parallels meet in the fourth vertex e. *)
    Exists.elim _ _ _ (pt_of_linesinter DE BE
        (lines_inter_of_crossing_parallels L N DE BE
            (fun (LN_eq : L = N) =>
                c_not_on_L
                    (Eq.elim _ N (fun X => OnLine c X)
                        (snd _ _ ac_on_N)
                        L
                        (Eq.symm _ _ _ LN_eq)))
            hLN_inter
            (snd _ _ hDE)
            (snd _ _ hBE)))
    (fun (e : Point) (he_on : OnLine e DE /\ OnLine e BE) =>

    have _ _ (para_symm L DE (snd _ _ hDE))
    (fun (hDE_para_L : para DE L) =>

    (* The constructed quadrilateral ADEB is a parallelogram. *)
    have _ (paragram a d e b N DE BE L)
    (And.intro _ _
        (And.intro _ _
            (And.intro _ _
                (And.intro _ _
                    (And.intro _ _
                        (And.intro _ _
                            (And.intro _ _
                                (And.intro _ _
                                    (And.intro _ _
                                        (fst _ _ ac_on_N)
                                        d_on_N)
                                    (fst _ _ hDE))
                                (fst _ _ he_on))
                            (snd _ _ he_on))
                        (fst _ _ hBE))
                    (snd _ _ ab_on_L))
                (fst _ _ ab_on_L))
            (snd _ _ hBE))
        hDE_para_L)
    (fun (hpar : paragram a d e b N DE BE L) =>

    have _ _ (len_eq_of_parallelogram' a d e b N DE BE L hpar)
    (fun (hab_ed : Length a b = Length e d) =>

    have _ _ (EqTrans _ _ _ _ hab_ed (length_symm e d))
    (fun (hab_de : Length a b = Length d e) =>

    have _ _ (len_eq_of_parallelogram a d e b N DE BE L hpar)
    (fun (had_eb : Length a d = Length e b) =>

    have _ _ (EqTrans _ _ _ _ had_eb (length_symm e b))
    (fun (had_be : Length a d = Length b e) =>

    have _ _ (length_pts_ne a b a d hd ab)
    (fun (ad : a ≠ d) =>

    have _ _ (length_pts_ne a b d e hab_de ab)
    (fun (de : d ≠ e) =>

    (* Euclid I.46 next invokes Prop. 29 on the transversal AD cutting the parallels AB and DE:
       angle BAD + angle ADE = two right angles. *)
    have _ _ (same_side_of_points_on_parallel b e N BE
        (fst _ _ hBE) (snd _ _ he_on)
        (snd _ _ hBE)
        b_not_on_N)
    (fun (b_e_same_side_N : SameSide b e N) =>

    have _ _
    (co_interior_angles b a d e L DE N
        (snd _ _ hDE)
        (snd _ _ ab_on_L) (fst _ _ ab_on_L) (Ne.symm _ _ _ ab)
        (fst _ _ hDE) (fst _ _ he_on) de
        (fst _ _ ac_on_N) d_on_N ad
        b_e_same_side_N)
    (fun (hBAD_ADE : Angle b a d + Angle a d e = 90 + 90) =>

    have _ _
    (fun (bad_col : colinear b a d) =>
        Exists.elim _ _ _ bad_col
        (fun (M : Line) (hM : OnLine b M /\ OnLine a M /\ OnLine d M) =>
            d_not_on_L
            (Eq.elim _ M (fun X => OnLine d X)
                (snd _ _ hM)
                L
                (Eq.symm _ _ _
                    (two_distinct_points_determine_unique_line a b L M ab
                        (fst _ _ ab_on_L) (snd _ _ ab_on_L)
                        (snd _ _ (fst _ _ hM)) (fst _ _ (fst _ _ hM)))))))
    (fun (tri_bad : triangle b a d) =>

    have _ _
    (right_of_online_right b a d c N
        (Ne.symm _ _ _ ca)
        tri_bad
        (fst _ _ ac_on_N)
        d_on_N
        (snd _ _ ac_on_N)
        (snd _ _ hc))
    (fun (hDAB : Angle b a d = 90) =>

    have _ _
    (CancelAdd (Angle a d e) 90 90
        (Eq.elim _ (Angle b a d) (fun x => x + Angle a d e = 90 + 90)
            hBAD_ADE
            90
            hDAB))
    (fun (hADE : Angle a d e = 90) =>

    have _ _
    (EqTrans _ _ _ _
        (Eq.symm _ _ _ (angle_symm b a d (Ne.symm _ _ _ ab) ad))
        hDAB)
    (fun (hDAB' : Angle d a b = 90) =>

    have _ _ (len_ang_arelen_ang_area_eq_of_parallelogram a d e b N DE BE L hpar)
    (fun (hpar_data : length a d = length e b /\ angle d a b = angle d e b /\ area a d b = area d e b) =>

    have _ _ (length_pts_ne a d e b had_eb ad)
    (fun (eb : e ≠ b) =>

    have _ _
    (EqTrans _ _ _ _
        (Eq.symm _ _ _ (snd _ _ (fst _ _ hpar_data)))
        hDAB')
    (fun (hDEB : Angle d e b = 90) =>

    have _ _
    (EqTrans _ _ _ _
        (Eq.symm _ _ _ (angle_symm d e b de eb))
        hDEB)
    (fun (hBED : Angle b e d = 90) =>

    have _ _ (para_symm N BE (snd _ _ hBE))
    (fun (hBE_para_N : para BE N) =>

    have _ (paragram d e b a DE BE L N)
    (And.intro _ _
        (And.intro _ _
            (And.intro _ _
                (And.intro _ _
                    (And.intro _ _
                        (And.intro _ _
                            (And.intro _ _
                                (And.intro _ _
                                    (And.intro _ _
                                        (fst _ _ hDE)
                                        (fst _ _ he_on))
                                    (snd _ _ he_on))
                                (fst _ _ hBE))
                            (snd _ _ ab_on_L))
                        (fst _ _ ab_on_L))
                    (fst _ _ ac_on_N))
                d_on_N)
            hDE_para_L)
        hBE_para_N)
    (fun (hpar_rot : paragram d e b a DE BE L N) =>

    have _ _ (len_ang_arelen_ang_area_eq_of_parallelogram d e b a DE BE L N hpar_rot)
    (fun (hpar_rot_data : length d e = length b a /\ angle e d a = angle e b a /\ area d e a = area e b a) =>

    have _ _
    (EqTrans _ _ _ _
        (Eq.symm _ _ _ (angle_symm a d e ad de))
        hADE)
    (fun (hEDA : Angle e d a = 90) =>

    have _ _
    (EqTrans _ _ _ _
        (Eq.symm _ _ _ (snd _ _ (fst _ _ hpar_rot_data)))
        hEDA)
    (fun (hEBA : Angle e b a = 90) =>

    have _ _
    (EqTrans _ _ _ _
        (angle_symm a b e ab (Ne.symm _ _ _ eb))
        hEBA)
    (fun (hABE : Angle a b e = 90) =>

    have _ _
    (EqTrans _ _ _ _
        hd
        had_be)
    (fun (hAB_BE : Length a b = Length b e) =>

    have _ _
    (EqTrans _ _ _ _
        hd
        (length_symm a d))
    (fun (hAB_DA : Length a b = Length d a) =>

	(* Step 9: package the witnesses — the square is a-b-e-d. *)
    Exists.intro _ _ e
    (Exists.intro _ _ d
        (And.intro _ _
            (And.intro _ _
                (And.intro _ _
                    (And.intro _ _
                        (And.intro _ _
                            (And.intro _ _
                                hAB_BE
                                hab_ed)
                            hAB_DA)
                        hABE)
                    hBED)
                hEDA)
            hDAB'))
    )))))))))))))))))))))))))))))))))))))))))))

(* Audit directive for the finished target theorem.
   The printed axiom list for square_of_len contains only the geometric base
   axioms from env.ncg and does not mention any placeholder theorem. *)
#print axioms square_of_len

Theorem square_exists : ∃ (a b c d : Point), square a b c d :=
    Exists.elim _ _ _ (pt_exists [] [] []) 
    (fun (a : Point) _ha =>

    Exists.elim _ _ _ (pt_exists [a] [] [])
    (fun (b : Point) hb =>
    
    have _ _ (distinct_from_single_point_ne _ _ _ _ hb)
    (fun (ba : b ≠ a) =>
    Exists.intro _ _ b (Exists.intro _ (fun x => ∃ c d, square b x c d) a (square_of_len b a ba))
    )))

